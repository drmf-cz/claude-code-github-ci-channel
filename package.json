{
  "name": "claude-beacon",
  "version": "1.2.0",
  "description": "Claude Code MCP channel plugin — pushes GitHub Actions CI/CD results into running Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-beacon": "dist/index.js",
    "claude-beacon-mux": "dist/mux.js"
  },
  "files": [
    "dist/",
    "config.example.yaml",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "start:mux": "bun run src/mux.ts",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun test && bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "watch": "bun run src/ghwatch.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "github-actions",
    "ci-cd",
    "channel",
    "webhook"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drmf-cz/claude-beacon.git"
  },
  "homepage": "https://github.com/drmf-cz/claude-beacon#readme",
  "bugs": {
    "url": "https://github.com/drmf-cz/claude-beacon/issues"
  }
}
