{
  "name": "claude-code-github-ci-channel",
  "version": "0.1.0",
  "description": "Claude Code MCP channel plugin — pushes GitHub Actions CI/CD results into running Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "bun run src/index.ts",
    "start:mux": "bun run src/mux.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "watch": "bun run src/ghwatch.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "github-actions",
    "ci-cd",
    "channel",
    "webhook"
  ],
  "license": "MIT"
}
